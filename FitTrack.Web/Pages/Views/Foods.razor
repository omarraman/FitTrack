@page "/foods"
@inject IFoodService Svc
@inject ConfirmService ConfirmSvc

<h1>Foods</h1>

<div class="card">
    <h3>@(_editId is null ? "Add food" : "Edit food")</h3>
    <p style="color: var(--text-dim); margin-top: 0;">All macros per 100 g.</p>
    <div class="form-row">
        <label>Name</label>
        <input @bind="_name" style="flex: 1; max-width: 400px;" />
        <label style="margin-left: 20px;">Brand</label>
        <input @bind="_brand" />
    </div>
    <div class="form-row">
        <label>Calories</label>
        <input type="number" step="0.1" min="0" @bind="_kcal" />
        <label style="margin-left: 20px;">Protein</label>
        <input type="number" step="0.1" min="0" @bind="_p" />
        <label style="margin-left: 20px;">Carbs</label>
        <input type="number" step="0.1" min="0" @bind="_c" />
        <label style="margin-left: 20px;">Fat</label>
        <input type="number" step="0.1" min="0" @bind="_f" />
        <label style="margin-left: 20px;">Fiber</label>
        <input type="number" step="0.1" min="0" @bind="_fib" />
    </div>
    <button class="btn" @onclick="Save" disabled="@(string.IsNullOrWhiteSpace(_name) || _busy)">@(_editId is null ? "Add" : "Save")</button>
    @if (_editId is not null)
    {
        <button class="btn btn-ghost" @onclick="CancelEdit">Cancel</button>
    }
</div>

<div class="card">
    <div class="card-row">
        <h3>All foods</h3>
        <input placeholder="Search…" @bind="_search" @bind:after="Reload" style="width: 240px;" />
    </div>
    <table class="table">
        <thead><tr><th>Name</th><th>Brand</th><th>kcal</th><th>P</th><th>C</th><th>F</th><th>Fiber</th><th style="width:150px;"></th></tr></thead>
        <tbody>
            @foreach (var f in _items)
            {
                <tr>
                    <td>@f.Name</td>
                    <td>@f.Brand</td>
                    <td>@f.CaloriesPer100g</td>
                    <td>@f.ProteinPer100g</td>
                    <td>@f.CarbsPer100g</td>
                    <td>@f.FatPer100g</td>
                    <td>@f.FiberPer100g</td>
                    <td>
                        <button class="btn btn-sm btn-ghost" @onclick="() => StartEdit(f)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Delete(f.Id)">×</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<FoodDto> _items = new();
    private string? _search;
    private int? _editId;
    private string _name = "";
    private string? _brand;
    private decimal _kcal, _p, _c, _f;
    private decimal? _fib;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.ListAsync(_search);

    private void StartEdit(FoodDto f)
    {
        _editId = f.Id;
        _name = f.Name; _brand = f.Brand;
        _kcal = f.CaloriesPer100g; _p = f.ProteinPer100g; _c = f.CarbsPer100g; _f = f.FatPer100g; _fib = f.FiberPer100g;
    }

    private void CancelEdit()
    {
        _editId = null;
        _name = ""; _brand = null;
        _kcal = _p = _c = _f = 0; _fib = null;
    }

    private async Task Save()
    {
        _busy = true;
        var dto = new UpsertFoodDto(_name, _brand, _kcal, _p, _c, _f, _fib);
        if (_editId is null) await Svc.CreateAsync(dto);
        else await Svc.UpdateAsync(_editId.Value, dto);
        CancelEdit();
        await Reload();
        _busy = false;
    }

    private async Task Delete(int id)
    {
        if (!await ConfirmSvc.ConfirmAsync("Delete this food? It will be removed from any recipes and diary entries.")) return;
        await Svc.DeleteAsync(id);
        await Reload();
    }
}
