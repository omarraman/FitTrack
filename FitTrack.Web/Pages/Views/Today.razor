@page "/"
@inject IWorkoutSessionService SessionSvc
@inject IMesocycleInstanceService InstanceSvc
@inject ConfirmService ConfirmSvc

<h1>Today's workout</h1>

@if (_loading)
{
    <p>Loading…</p>
}
else if (_session is null)
{
    <div class="card">
        <h3>Nothing scheduled</h3>
        <p>You don't have any active workout for today. Start a new mesocycle instance from the <a href="/instances">Instances</a> page.</p>
    </div>
}
else
{
        <div class="card">
            <div class="card-row">
                <div>
                    <h2>@_session.WorkoutName <span class="badge">Week @_session.WeekNumber</span></h2>
                    <small style="color: var(--text-dim);">Originally scheduled @_session.ScheduledDate.ToString("yyyy-MM-dd")</small>
                </div>
                <div>
                    @if (_session.CompletedAt is not null)
                    {
                        <span class="badge ok">Completed @_session.CompletedAt.Value.ToLocalTime():HH:mm</span>
                    }
                    else
                    {
                        <button class="btn btn-ok" @onclick="CompleteSession" disabled="@_busy">Mark session complete</button>
                        <button class="btn btn-sm btn-ghost" style="margin-top:6px;" @onclick="SkipSession" disabled="@_busy">Skip this session</button>
                        <button class="btn btn-sm btn-ghost" style="margin-top:6px;" @onclick="SkipWeek" disabled="@_busy">Close week @_session.WeekNumber early</button>
                    }
                </div>
            </div>

        @foreach (var group in _session.Logs.GroupBy(l => new { l.ExerciseId, l.ExerciseName }).OrderBy(g => g.Min(l => l.Id)))
        {
            <div class="card" style="background: var(--panel-2);">
                <h3 style="color: var(--text);">@group.Key.ExerciseName</h3>
                <table class="table workout-log-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">Set</th>
                            <th>Target</th>
                            <th>Actual reps</th>
                            <th>Actual kg</th>
                            <th>Notes</th>
                            <th style="width: 90px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in group.OrderBy(l => l.SetNumber))
                        {
                            <tr>
                                <td data-label="Set">@log.SetNumber</td>
                                <td data-label="Target"><span class="badge">@log.TargetReps × @log.TargetWeightKg kg</span></td>
                                <td data-label="Actual reps">
                                    <input type="number" min="0" step="1"
                                           value="@_edits[log.Id].Reps"
                                           @onchange="@((ChangeEventArgs e) => OnRepsChanged(log.Id, e))" />
                                </td>
                                <td data-label="Actual kg">
                                    <input type="number" min="0" step="0.5"
                                           value="@_edits[log.Id].Kg"
                                           @onchange="@((ChangeEventArgs e) => OnKgChanged(log.Id, e))" />
                                </td>
                                <td data-label="Notes">
                                    <input type="text"
                                           value="@_edits[log.Id].Notes"
                                           @onchange="@((ChangeEventArgs e) => OnNotesChanged(log.Id, e))" />
                                </td>
                                <td data-label="Action">
                                    <button class="btn btn-sm" @onclick="() => SaveLog(log.Id)" disabled="@_busy">Log</button>
                                    @if (log.PerformedAt is not null)
                                    {
                                        <div style="font-size: 11px; color: var(--text-dim); margin-top: 2px;">saved</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private WorkoutSessionDto? _session;
    private bool _loading = true;
    private bool _busy;

    private record Edit { public int? Reps; public decimal? Kg; public string? Notes; }
    private Dictionary<int, Edit> _edits = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _loading = true;
        _session = await SessionSvc.GetTodaysSessionAsync();
        _edits = new();
        if (_session is not null)
        {
            foreach (var l in _session.Logs)
            {
                _edits[l.Id] = new Edit
                {
                    Reps = l.ActualReps ?? l.TargetReps,
                    Kg = l.ActualWeightKg ?? l.TargetWeightKg,
                    Notes = l.Notes
                };
            }
        }
        _loading = false;
    }

    private void OnRepsChanged(int logId, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) _edits[logId].Reps = v;
        else _edits[logId].Reps = null;
    }

    private void OnKgChanged(int logId, ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var v))
            _edits[logId].Kg = v;
        else _edits[logId].Kg = null;
    }

    private void OnNotesChanged(int logId, ChangeEventArgs e)
        => _edits[logId].Notes = e.Value?.ToString();

    private async Task SaveLog(int logId)
    {
        _busy = true;
        var e = _edits[logId];
        await SessionSvc.LogSetAsync(logId, new UpdateExerciseLogDto(e.Reps, e.Kg, e.Notes));
        await Reload();
        _busy = false;
    }

    private async Task CompleteSession()
    {
        if (_session is null) return;
        _busy = true;
        await SessionSvc.CompleteSessionAsync(_session.Id);
        await Reload();
        _busy = false;
    }

    private async Task SkipSession()
    {
        if (_session is null) return;
        if (!await ConfirmSvc.ConfirmAsync("Skip this session? It will be removed from the queue.", "Skip session")) return;
        _busy = true;
        await SessionSvc.SkipSessionAsync(_session.Id);
        await Reload();
        _busy = false;
    }

    private async Task SkipWeek()
    {
        if (_session is null) return;
        if (!await ConfirmSvc.ConfirmAsync(
            $"Close week {_session.WeekNumber} early? All remaining sessions in week {_session.WeekNumber} will be skipped.",
            "Close week")) return;
        _busy = true;
        await SessionSvc.SkipWeekAsync(_session.MesocycleInstanceId, _session.WeekNumber);
        await Reload();
        _busy = false;
    }
}
