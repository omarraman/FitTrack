<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-omarraman" value="https://nuget.pkg.github.com/omarraman/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-omarraman>
      <add key="Username" value="omarraman" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-omarraman>
  </packageSourceCredentials>
</configuration>

